# ============================================================
# Rodinný kalendář — Environment variables template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=local

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://rodinkal:changeme@localhost:5432/rodinkal?schema=public"

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_byte_random_hex

# --- Resend (email) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=kalendar@yourdomain.com

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- File uploads ---
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=20

# --- S3 storage (optional — omit S3_BUCKET to use local disk) ---
# S3_BUCKET=your-bucket-name
# AWS_REGION=eu-central-1
# S3_PREFIX=rodinny-kalendar/uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Feature flags (overrides DB defaults at startup) ---
# Set to "false" to force-disable regardless of DB flag
FEATURE_SMS_NOTIFICATIONS=false

# --- SMS (optional, Czech gateway) ---
# GOSMS_API_KEY=
# GOSMS_CHANNEL_ID=

# --- Cloudflare Tunnel (production only) ---
# TUNNEL_TOKEN=

# --- Deploy webhook (Synology → NAS endpoint) ---
# DEPLOY_WEBHOOK_SECRET=

# --- Logging ---
LOG_LEVEL=info

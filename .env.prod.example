# ── Rodinka — Production environment ────────────────────────────────────────
# Copy to .env.prod and fill in real values. NEVER commit .env.prod to git.

# Database password (choose a strong random password)
DB_PASSWORD=change_me_strong_password

# Session secret — at least 64 random characters
# Generate: openssl rand -hex 32
SESSION_SECRET=change_me_64_char_random_secret

# Resend.com email API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Web Push VAPID keys
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@krataf.dev

# GitHub Actions deploy webhook secret (random string you pick)
# Set the same value in GitHub → Settings → Secrets → DEPLOY_WEBHOOK_SECRET
DEPLOY_WEBHOOK_SECRET=change_me_webhook_secret

# Optional: S3 / Cloudflare R2 for file storage
# Leave blank to use local filesystem (volumes)
S3_BUCKET=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

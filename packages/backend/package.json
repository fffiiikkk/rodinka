{
  "name": "@rodinkal/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose src/services/__tests__",
    "test:integration": "vitest run --reporter=verbose src/__tests__",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@prisma/client": "^5.19.1",
    "@rodinkal/shared": "*",
    "argon2": "^0.41.1",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.0",
    "helmet": "^8.0.0",
    "ical-generator": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "resend": "^4.0.1",
    "rrule": "^2.8.1",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "prisma": "^5.19.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
